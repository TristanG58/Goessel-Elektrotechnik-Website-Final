# Vite-Env-Variablen für die BookingForm.
# Kopiere diese Datei zu .env (lokal) und setze die Werte.
# Auf Vercel: Project Settings → Environment Variables.

# n8n Webhook-URL für das Lead-Empfang-Workflow (siehe workflows/01-lead-empfang.json)
VITE_N8N_WEBHOOK_URL=https://<dein-account>.app.n8n.cloud/webhook/goessel-anfrage

# X-Form-Key (Bot-Deterrent, kein echtes Secret — wird ins JS-Bundle gebakt).
# Muss identisch sein in: n8n Workflow 1 + Workflow 2 + Apps Script Skript-Property FORM_KEY.
VITE_FORM_KEY=replace-with-random-uuid-or-hex-string
